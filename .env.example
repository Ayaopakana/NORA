# Базовый URL API (без завершающего слэша). Пример после появления бэкенда:
# VITE_API_URL=http://localhost:3000/api

# Карта 2ГИС (MapGL): https://platform.2gis.ru/
# Нужен ключ с доступом к Map Tiles / векторным тайлам (см. раздел MapGL в документации).
# После изменения .env перезапустите dev-сервер (Vite подхватывает env только при старте).
# Если видите «key is invalid»: проверьте срок демо, тип ключа и ограничения по домену (localhost:5173).
# VITE_2GIS_API_KEY=

# Ночной/кастомный стиль карты: создайте стиль в https://styles.2gis.com (шаблон «Ночь»),
# Поделиться → скопируйте идентификатор сюда. Тогда карта использует настоящие тёмные тайлы (инверсия в коде отключится).
# VITE_2GIS_MAP_STYLE=

# Язык подписей на карте (по умолчанию ru).
# VITE_2GIS_MAP_LANG=ru

# true — отключить ночную инверсию canvas (останется дневной стиль MapGL по умолчанию).
# VITE_2GIS_MAP_NO_INVERT=true
