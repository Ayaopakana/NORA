# SQLite по умолчанию (файл в server/prisma/). Для Postgres:
# DATABASE_URL="postgresql://user:pass@localhost:5432/nora"

DATABASE_URL="file:./dev.db"

PORT=3001
JWT_SECRET=change-me-in-production

# Через запятую; пусто = разрешить любой origin (удобно в dev)
CORS_ORIGINS=http://localhost:3000

# 2GIS: только геокодинг мест и пешеходные маршруты (карта остаётся MapLibre)
# Ключ: https://platform.2gis.ru/
DGIS_API_KEY=
